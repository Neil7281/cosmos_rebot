# Copy this to .env and fill in your values
# The launch script sources this file automatically

# Number of GPUs to use for training (minimum 2 × A100 80 GB)
N_GPUS=2

# CUDA version: cu128 for CUDA 12.x drivers | cu130 for CUDA 13.x drivers
CUDA_GROUP=cu128

# HuggingFace token — needed if the dataset is gated, AND/OR to push the
# trained checkpoint to your own HF Hub model repo (see HF_PUSH_REPO below)
# HF_TOKEN=hf_xxxx

# HF Hub model repo to push the trained checkpoint to after training (optional)
# Format: <username>/<model-name>. Leave unset to skip the push step.
# HF_PUSH_REPO=my-username/my-model-name

# Working directory — all downloads go here. Defaults to ./workdir
# WORK_DIR=/scratch/neel/cosmos_workdir

# W&B logging (optional). Set wandb_mode = "online" in the TOML as well.
# WANDB_API_KEY=xxxx
